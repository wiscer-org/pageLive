{
  "manifest_version": 3,
  "name": "PageLive",
  "version": "4.1.3",
  "description": "Keyboard shortcuts and screen reader companion for ChatGPT, Gemini, Grok, and Claude",
  "permissions": [],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://grok.com/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://mail.google.com/*",
    "https://www.audible.com/*",
    "https://open.spotify.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://docs.google.com/*",
    "https://www.reddit.com/*",
    "https://*.slack.com/*",
    "https://www.youtube.com/*",
    "https://outlook.office.com/*",
    "https://web.whatsapp.com/*",
    "https://discord.com/*",
    "https://teams.microsoft.com/*",
    "https://www.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/",
        "https://gemini.google.com/app/*"
      ],
      "js": [
        "content-scripts/gemini.js"
      ],
      "css": [
        "assets/pagelive.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://grok.com/*"
      ],
      "js": [
        "content-scripts/grok.js"
      ],
      "css": [
        "assets/pagelive.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "content-scripts/claude.js"
      ],
      "css": [
        "assets/pagelive.css"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content-scripts/chatgpt.js"
      ],
      "css": [
        "assets/pagelive.css"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "pagelive-16.png",
    "48": "pagelive-48.png",
    "128": "pagelive-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pagelive.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
